# =============================================================================
# Uwitz Project Environment Variables
# =============================================================================
# Convention: UZC_SECTION__KEY (double underscore = nesting separator)
# Copy this file to .env and fill in real values. Never commit .env files.
# =============================================================================

# --- Server ---
# UZC_SERVER__HOST=0.0.0.0
# UZC_SERVER__PORT=8080

# --- Database ---
# UZC_DATABASE__URL=postgresql://user:pass@localhost:5432/db
# UZC_DATABASE__MAX_CONNECTIONS=10

# --- Auth ---
# UZC_AUTH__JWT_SECRET=<generate-with-openssl rand -hex 32>
# UZC_AUTH__TOKEN_EXPIRY=3600

# --- Logging ---
# UZC_LOG__LEVEL=info
# UZC_LOG__FORMAT=json

# --- TLS ---
# UZC_TLS__ENABLED=false
# UZC_TLS__CERT_PATH=
# UZC_TLS__KEY_PATH=
